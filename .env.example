# =============================================================================
# RAG Playground — Environment Configuration
# Copy this file to .env and adjust as needed
# =============================================================================

# --- Chat Provider ---
# Provider: "ollama" (default)
CHAT_PROVIDER=ollama
# Default model: Qwen 2.5 7B — strong open model, runs well locally
CHAT_MODEL=qwen2.5:7b
# Ollama server host
OLLAMA_HOST=http://localhost:11434

# --- Embedding Provider ---
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# --- Pipeline Defaults ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
TEMPERATURE=0.1
DATA_DIR=./data
LOG_LEVEL=info

# =============================================================================
# Swapping models — just change CHAT_MODEL or EMBED_MODEL:
#
# CHAT_MODEL=llama3.2         # lighter, faster
# CHAT_MODEL=qwen2.5:14b      # more capable, needs more RAM
# CHAT_MODEL=mistral:7b        # alternative 7B model
#
# EMBED_MODEL=mxbai-embed-large   # 1024d, ~669MB
# EMBED_MODEL=bge-m3              # 1024d, multilingual
# =============================================================================

# =============================================================================
# Future: OpenAI-compatible provider
# (To use, set CHAT_PROVIDER=openai and provide the following)
#
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# =============================================================================
